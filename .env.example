# Hospital IoT Monitor — Environment Configuration
# Copy to .env and adjust for your deployment.

# --- Sensor Simulation ---
HEART_RATE_MIN=45
HEART_RATE_MAX=150
TEMP_MIN=34.5
TEMP_MAX=40.5
WATER_USAGE_MIN=5
WATER_USAGE_MAX=45

# --- Daemon Settings ---
LOG_DIR=active_logs
PID_FILE=/tmp/hospital_system.pid
LOG_INTERVAL_SECONDS=1

# --- Security ---
LOG_DIR_PERMISSIONS=700
LOG_FILE_PERMISSIONS=600

# --- Analysis Thresholds ---
CRITICAL_HR_LOW=60
CRITICAL_HR_HIGH=100
CRITICAL_TEMP_HIGH=38.0
CRITICAL_TEMP_LOW=35.5
WATER_HIGH_USAGE=35

# --- Deployment ---
DOCKER_TAG=latest
CONTAINER_NAME=hospital-iot-monitor
